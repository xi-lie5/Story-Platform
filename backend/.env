# ==================== AI服务核心配置 ====================
# 是否使用Mock数据（开发阶段设为true，生产阶段设为false）
USE_MOCK_AI=true
# AI服务类型：改为modelscope（魔搭社区）
AI_SERVICE_TYPE=modelscope

# 魔搭社区访问令牌（替换为你获取的令牌）
MODELSCOPE_TOKEN=ms-1cf04567-fd11-4a9d-a02f-aad3ac644bb7

# 魔搭模型ID（推荐选择对话模型，可替换为其他模型，见下方说明）
MODELSCOPE_MODEL_ID=qwen-7b-chat # 可选：llama3-8b-chat、ernie-bot-3.5、baichuan2-7b-chat
# 魔搭API基础地址（固定，无需修改）
MODELSCOPE_API_BASE_URL=https://modelscope.cn/api/v1/models

# 服务器端口（随便写，比如5000）
PORT=5000

# JWT密钥（随便写一串字符，如abc123456）
